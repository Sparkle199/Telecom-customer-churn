\pard\sb320\sa200\f0\fs32\b\cf1 Task 8 -- Evaluation\b0\cf0\par
\pard\sa160\f0\fs22 Steps:\par
\pard\li480\fi-240\f0\fs22 1.\tab Load Paul's saved test predictions and labels.\par
\pard\li480\fi-240\f0\fs22 2.\tab Report precision/recall/F1 and ROC-AUC -- accuracy alone is misleading given the ~26.5% class imbalance.\par
\pard\li480\fi-240\f0\fs22 3.\tab State which metric matters most for a retention use case (a missed churner usually costs more than a false alarm) and pick/justify a decision threshold accordingly, rather than defaulting to 0.5.\par
\pard\sa40\sb80\li360\f1\fs19\cf1\b CODE HINT\b0\cf0\par
\pard\li360\sa20\f1\fs19 import pandas as pd\par
\pard\li360\sa20\f1\fs19 from sklearn.metrics import (classification_report, roc_auc_score,\par
\pard\li360\sa20\f1\fs19                               confusion_matrix, RocCurveDisplay)\par
\pard\li360\sa20\f1\fs19 \par
\pard\li360\sa20\f1\fs19 test_proba = pd.read_csv('models/test_predictions.csv', index_col=0)\par
\pard\li360\sa20\f1\fs19 y_test = pd.read_csv('models/test_labels.csv', index_col=0)\par
\pard\li360\sa20\f1\fs19 \par
\pard\li360\sa20\f1\fs19 y_pred = (test_proba >= 0.5).astype(int)\par
\pard\li360\sa20\f1\fs19 print(classification_report(y_test, y_pred))\par
\pard\li360\sa20\f1\fs19 print('ROC-AUC:', roc_auc_score(y_test, test_proba))\par
\pard\li360\sa20\f1\fs19 print(confusion_matrix(y_test, y_pred))\par
\pard\li360\sa20\f1\fs19 \par
\pard\li360\sa20\f1\fs19 RocCurveDisplay.from_predictions(y_test, test_proba)\par
\pard\sa160\f0\fs22\par
\pard\sb320\sa200\f0\fs32\b\cf1 Task 9 -- Interpretation\b0\cf0\par
\pard\sa160\f0\fs22 Steps:\par
\pard\li480\fi-240\f0\fs22 1.\tab Pull feature importances (or coefficients) from Paul's model.\par
\pard\li480\fi-240\f0\fs22 2.\tab Translate the top drivers into plain-language retention insights -- e.g. which contract types, services, or tenure ranges are associated with churn.\par
\pard\sa40\sb80\li360\f1\fs19\cf1\b CODE HINT\b0\cf0\par
\pard\li360\sa20\f1\fs19 import joblib\par
\pard\li360\sa20\f1\fs19 model = joblib.load('models/best_model.joblib')\par
\pard\li360\sa20\f1\fs19 \par
\pard\li360\sa20\f1\fs19 importances = pd.Series(\par
\pard\li360\sa20\f1\fs19     model.feature_importances_, index=X_train.columns\par
\pard\li360\sa20\f1\fs19 ).sort_values(ascending=False)\par
\pard\li360\sa20\f1\fs19 importances.head(10)\par
\pard\li360\sa20\f1\fs19 \par
